    global.spawn_len_var = 1;
    global.spawn_arr[0,0] = 40;
    global.spawn_arr[0,1] = 324;
    global.spawn_arr[0,2] = 0;
    global.spawn_arr[0,3] = 0;
    // 3D Draw
    d3d_start();
    global.draw_3d_var = true;
    // Doors
    spawn_create_scr(true,false);
');
