    global.mark_arr[4,0] = 627;
    global.mark_arr[4,1] = 653;
    global.mark_arr[4,2] = 0;
    mark_create_scr();
    // 3D Draw
    d3d_start();
    global.draw_3d_var = true;
    // Doors
    spawn_create_scr(true,false);
")
