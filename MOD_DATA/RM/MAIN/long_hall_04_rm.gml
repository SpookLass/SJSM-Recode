room_set_code
(
    argument0,"
    ini_open(global.lang_var);
	global.rm_name_var = ini_read_string('ROOM','long','ROOM_long')+' 4';
	ini_close();
    // Spawn
    global.spawn_len_var = 2;
    global.spawn_arr[0,0] = 112;
    global.spawn_arr[0,1] = 464;
    global.spawn_arr[0,2] = 0;
    global.spawn_arr[0,3] = 0;
    global.spawn_arr[1,0] = 1232;
    global.spawn_arr[1,1] = 656;
    global.spawn_arr[1,2] = 0;
    global.spawn_arr[1,3] = 180;
    // Mark
    global.mark_len_var = 5;
    global.mark_arr[0,0] = 223;
    global.mark_arr[0,1] = 464;
    global.mark_arr[0,2] = 0;
    global.mark_arr[1,0] = 357;
    global.mark_arr[1,1] = 458;
    global.mark_arr[1,2] = 0;
    global.mark_arr[2,0] = 510;
    global.mark_arr[2,1] = 463;
